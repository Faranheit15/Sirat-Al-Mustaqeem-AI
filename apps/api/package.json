{
  "name": "@sirat/api",
  "private": true,
  "scripts": {
    "dev": "uv run --cache-dir .uv-cache uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "uv sync --frozen --cache-dir .uv-cache",
    "lint": "uv run --cache-dir .uv-cache ruff check .",
    "typecheck": "uv run --cache-dir .uv-cache mypy app"
  },
  "dependencies": {
    "turbo": "^2.9.14"
  }
}
