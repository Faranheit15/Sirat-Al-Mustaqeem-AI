ENVIRONMENT="local"
API_TITLE="Sirat Al Mustaqeem AI API"
API_VERSION="0.1.0"
API_CORS_ORIGINS="http://localhost:3000"

# Local Swagger UI convenience only. In deployed environments, set
# ENVIRONMENT="production" and AUTH_REQUIRED="true".
AUTH_REQUIRED="false"
LOCAL_DEV_USER_ID="00000000-0000-4000-8000-000000000000"
LOCAL_DEV_USER_EMAIL="local-dev@sirat.local"

SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_JWT_AUDIENCE="authenticated"

GROQ_API_KEY="replace-with-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"
GEMINI_API_KEY="replace-with-gemini-api-key"
GEMINI_MODEL="gemini-3.5-flash"
OPENROUTER_API_KEY="replace-with-openrouter-api-key"
OPENROUTER_MODEL="meta-llama/llama-3.1-70b-instruct"

RATE_LIMIT_REQUESTS_PER_MINUTE="20"
JWKS_CACHE_TTL_SECONDS="3600"
HTTP_TIMEOUT_SECONDS="30"
LOG_LEVEL="INFO"
