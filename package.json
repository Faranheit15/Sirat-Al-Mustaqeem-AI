{
  "name": "sirat-al-mustaqeem-ai",
  "private": true,
  "packageManager": "bun@1.1.45",
  "scripts": {
    "dev": "bunx turbo dev",
    "build": "bunx turbo build",
    "lint": "bunx turbo lint",
    "typecheck": "bunx turbo typecheck",
    "format": "bunx prettier --write .",
    "dev:web": "bunx turbo dev --filter=@sirat/web",
    "build:web": "bunx turbo build --filter=@sirat/web",
    "lint:web": "bunx turbo lint --filter=@sirat/web",
    "typecheck:web": "bunx turbo typecheck --filter=@sirat/web",
    "dev:api": "bunx turbo dev --filter=@sirat/api",
    "build:api": "bunx turbo build --filter=@sirat/api",
    "lint:api": "bunx turbo lint --filter=@sirat/api",
    "typecheck:api": "bunx turbo typecheck --filter=@sirat/api"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.9.14",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
